# Fleet1 Backend Environment Variables
# Copy to .env and fill with your Supabase values

# Supabase PostgreSQL connection
# Format: postgresql://postgres:[PASSWORD]@db.[PROJECT_REF].supabase.co:5432/postgres
SUPABASE_DB_URL=postgresql://postgres:your-password@db.your-project-ref.supabase.co:5432/postgres

# JWT secret for token signing (min 32 chars recommended)
JWT_SECRET=your-super-secret-jwt-key-min-32-chars

# Environment: development | production
FLASK_ENV=development

# CORS origins (comma-separated). Add your Vercel URL for production
# Example: https://your-app.vercel.app,https://your-app-*.vercel.app
CORS_ORIGINS=http://localhost:3000,http://localhost:5173,http://127.0.0.1:3000,http://127.0.0.1:5173
